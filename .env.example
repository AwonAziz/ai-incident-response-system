# ── AI Incident Response System — Environment Config ──────────────────
# Copy this to .env and fill in your values.
# Never commit your actual .env to version control.

# Pipeline timing
COLLECTION_INTERVAL=5        # seconds between metric collections
DEDUP_WINDOW=60              # seconds before re-alerting same resource
AUTO_RESOLVE_MINUTES=10      # auto-resolve MEDIUM/LOW after N minutes

# ML model
MODEL_CONTAMINATION=0.05     # expected fraction of anomalies (0.01–0.1)
MODEL_N_ESTIMATORS=150       # Isolation Forest trees (more = slower but accurate)
BASELINE_SAMPLES=500         # training rounds per collector

# Notifications (leave blank to disable)
SLACK_WEBHOOK_URL=
PAGERDUTY_ROUTING_KEY=

# Output
QUIET_MODE=false             # set true to suppress LOW severity console alerts
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
